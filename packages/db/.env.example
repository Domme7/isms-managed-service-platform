# @isms/db – Beispiel-Umgebungsvariablen (nur Platzhalter, KEINE echten Secrets).
# Dev/Test laufen ohne diese Datei gegen PGlite (in-memory, kein Docker).
# Diese Werte gelten nur für den optionalen Docker-Postgres-Server (docker-compose.yml).

# Treiberwahl der DB-Provider-Factory: pglite (Default) | pg
# WICHTIG: DB_DRIVER=pg gilt NUR für den optionalen Docker-Postgres-Server (docker-compose.yml).
# Für lokale Dev/Test OHNE Docker den Default `pglite` verwenden (nicht setzen) — sonst aktiviert
# ein versehentliches Kopieren dieser Datei nach `.env` ungewollt den Server-Pfad (DATABASE_URL).
DB_DRIVER=pg

# PostgreSQL-Zugangsdaten (Platzhalter — vor echter Nutzung ersetzen, nie committen)
POSTGRES_USER=isms
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=isms

# Verbindungs-URL für den pg-Treiber (muss zu den POSTGRES_*-Werten passen)
DATABASE_URL=postgres://isms:change-me-locally@localhost:5432/isms
